# Copy this file to .env and fill in real values. NEVER commit .env.

# ---- LLM provider (backend only — never exposed to the frontend) ----
# Get a free key at https://openrouter.ai — works with Gemini, Llama, and more.
LLM_API_KEY=your-openrouter-api-key-here
# OpenAI-compatible base URL. Change to use a different provider.
LLM_BASE_URL=https://openrouter.ai/api/v1

# ---- Model failover pools ----
# Ordered, comma-separated model ids (strongest first). Position 0 is what runs
# on a healthy request; the app fails over down the list when a model returns
# HTTP 429 (rate-limited). Set either var to the literal "auto" to instead
# discover free models from OpenRouter's catalog at runtime — your account's
# allowed-models list then gates which are actually used (zero local change when
# you add/remove models on OpenRouter).
LLM_SYNTHESIS_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free,nousresearch/hermes-3-llama-3.1-405b:free,openai/gpt-oss-120b:free,openrouter/owl-alpha
LLM_RERANK_MODELS=meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-nano-30b-a3b:free,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# When a model is rate-limited, skip it for this long (fallback if the upstream
# Retry-After header is absent), and how long to cache the auto-discovered list.
LLM_COOLDOWN_SECONDS=60
LLM_MODELS_CACHE_TTL=3600

# Legacy single-model vars (still honored if the *_MODELS pools are unset).
LLM_SYNTHESIS_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
LLM_RERANK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- Pipeline bounds (cost control) ----
MAX_CANDIDATES=50
MAX_RETAINED_PAPERS=18
MAX_CONCURRENT_RUNS=3
DAILY_TOKEN_BUDGET=2000000
RATE_LIMIT_PER_MINUTE=10

# ---- arXiv ----
ARXIV_PAGE_SIZE=50

# ---- Backend server ----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# Comma-separated allowed origins for CORS. The UI is served same-origin by this
# app; these only matter for cross-origin API clients. No wildcards.
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ---- Storage (v1) ----
DATABASE_URL=sqlite:///./data/app.db

# ---- Frontend (safe to expose; must be NEXT_PUBLIC_*) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
